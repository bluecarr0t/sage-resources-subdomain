# Copy to .env.local for local development.
# Production: set the same keys in Vercel → Project → Environment Variables.

# --- Phase 0 SEO instrumentation (required for organic traffic measurement) ---

# GA4 measurement ID (format G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console HTML tag verification (content value only, not full meta tag)
NEXT_PUBLIC_GOOGLE_VERIFICATION_CODE=

# IndexNow (Bing/Yandex). Generate: openssl rand -hex 16
INDEXNOW_KEY=

# Optional: canonical site URL for IndexNow + audits (defaults to resources subdomain)
SITE_URL=https://resources.sageoutdooradvisory.com

# --- Job Pipeline email (Resend) ---
# Domain: alerts.sageoutdooradvisory.com (verified in Resend dashboard)
RESEND_API_KEY=
RESEND_FROM_EMAIL=active-jobs@alerts.sageoutdooradvisory.com
RESEND_REPLY_TO=hello@sageoutdooradvisory.com
# Set to false locally to skip sends; production requires RESEND_API_KEY + true
PIPELINE_EMAIL_ENABLED=true

# Recommended: protects /api/indexnow cron when set
CRON_SECRET=

# Public map API scraper guard (/api/properties, /api/google-places, /api/google-places-photo)
# Set a strong random value in production; pass as header x-public-map-api-key for scripts/CI
PUBLIC_MAP_API_BYPASS_SECRET=
# Per-IP limits (combined across map routes; uses Redis when REDIS_URL is set)
# PUBLIC_MAP_API_RATELIMIT_PER_MIN=60
# PUBLIC_MAP_API_RATELIMIT_PER_HOUR=300
# GOOGLE_PLACES_PUBLIC_ROUTE_RATELIMIT_PER_MIN=30
# GOOGLE_PLACES_PHOTO_ROUTE_RATELIMIT_PER_MIN=40
# PUBLIC_MAP_API_GUARD_DISABLED=true  # local debug only — never in production

# --- Auto-ban abusive IPs to the Vercel Firewall (cron: /api/cron/ban-abusive-ips) ---
# REQUIRED in production to block scrapers (e.g. OutReserveBot). Also set in Vercel dashboard:
#   Firewall → Bot Protection → Active (not Logging only)
PUBLIC_MAP_API_AUTO_BAN_ENABLED=true
# Rate-limit offenses (within 1h) before an IP is queued for a firewall ban
# PUBLIC_MAP_API_ABUSE_BAN_THRESHOLD=10
# Vercel REST API access for writing IP blocks (Account Settings → Tokens)
# VERCEL_FIREWALL_API_TOKEN=     # or reuse VERCEL_TOKEN
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=                # required for team-scoped projects

# --- DigitalOcean read-only OTA databases (scripts/sync-do-to-supabase) ---
# Three databases on the same host: campings (Dec 2024+), hipcamp, campspot (legacy archives)
DIGITALOCEAN_DB_HOST=
DIGITALOCEAN_DB_PORT=5432
DIGITALOCEAN_DB_USER=
DIGITALOCEAN_DB_PASSWORD=
# Legacy alias used by migrate-legacy-* scripts (defaults to campings)
LEGACY_CAMPING_DB_NAME=campings

# Direct Postgres URL for bulk sync/import (Supabase Dashboard > Database > Connection string, transaction mode)
# Required on Vercel for Sage AI OTA monthly exports (DigitalOcean is IP-restricted).
SUPABASE_DB_URL=

# Phase 4 downstream refresh (npm run refresh:downstream): unified_comps + RV overview scan
# NEXT_PUBLIC_SUPABASE_URL= and SUPABASE_SECRET_KEY= (same as production app)
# Optional: UPSTASH_REDIS_REST_URL= / UPSTASH_REDIS_REST_TOKEN= to clear comps facets cache

# --- Zapier → GoHighLevel (server-only; no NEXT_PUBLIC_ prefix) ---
# Catch Hook URLs from Webhooks by Zapier (one Zap per flow)
# ZAPIER_NEWSLETTER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...
# ZAPIER_GATED_LEAD_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...

# Pipeline Quarterly paid product MVP (404 in all envs unless explicitly enabled)
# ENABLE_PIPELINE_QUARTERLY_PRODUCT=true

# Pipeline Quarterly → Google Sheets export
# Option A (server-owned, link-shareable): service account JSON key — blocked on some GCP orgs
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...@....iam.gserviceaccount.com",...}
# Option B (split fields)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=...@....iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#
# Option C (recommended when service account keys are disabled): OAuth Web client — no JSON key download
# 1. GCP Console → APIs & Services → Credentials → Create credentials → OAuth client ID → Web application
# 2. Authorized JavaScript origins: http://localhost:3003 (and your production URL)
# 3. Enable Google Sheets API + Google Drive API on the project
# 4. OAuth consent screen: add scope https://www.googleapis.com/auth/spreadsheets.readonly (Project Pipeline)
# NEXT_PUBLIC_GOOGLE_SHEETS_OAUTH_CLIENT_ID=123456789-abc.apps.googleusercontent.com

# Project Pipeline (reads private Google Sheet via service account or OAuth above)
# GOOGLE_PROJECT_PIPELINE_SHEET_ID=1q9LzRoP_lDmiXaXLEL9HwXGjVPdNon0EoZ3yY4vrk3A
# GOOGLE_PROJECT_PIPELINE_SHEET_NAME=2026 Jobs
# Service account: share the sheet with GOOGLE_SERVICE_ACCOUNT_EMAIL as Viewer
# OAuth: user who connects must already have access to the sheet in Google Drive
# Cron sync (/api/cron/sync-project-pipeline) mirrors all pipeline tabs (2026–2020) into
# project_pipeline_jobs with sheet_name + sheet_year. Schedule: hourly at :30 UTC (vercel.json).
# Production: set GOOGLE_SERVICE_ACCOUNT_* so cron runs without per-user OAuth backfill.
# Run npm run migrate:project-pipeline then npm run sync:project-pipeline to backfill historical years.

# Pipeline Slack DMs (optional — review / due-date notifications)
# SLACK_BOT_TOKEN=xoxb-…
# PIPELINE_SLACK_ENABLED=true

# #website channel posts (optional — Glamping Market Overview signups)
# Invite the sage_job_pipeline bot to #website, then set:
# WEBSITE_SLACK_ENABLED=true
# WEBSITE_SLACK_CHANNEL_ID=C0BJZDM2C3D
# Optional Incoming Webhook alternative (skips bot token for this channel):
# WEBSITE_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/…

# Pipeline review calendar events (optional — Google Calendar for PM on submit/resubmit)
# Requires Google Calendar API + domain-wide delegation for calendar.events on the service account.
# PIPELINE_CALENDAR_ENABLED=true  # Creates PM calendar placeholders on submit/resubmit (next business day 9am)
# GOOGLE_CALENDAR_TIMEZONE=America/New_York
# PIPELINE_CALENDAR_TEST_RECIPIENT=harsell@sageoutdooradvisory.com

# --- QuickBooks Online (Admin → QuickBooks invoice remapper; role=admin only) ---
# Create an Intuit developer app: https://developer.intuit.com/app/developer/qbo/docs/develop
# Redirect URI must match (default shown on /admin/quickbooks status panel):
#   https://resources.sageoutdooradvisory.com/api/admin/quickbooks/oauth/callback
#   http://localhost:3003/api/admin/quickbooks/oauth/callback
# Apply migration: scripts/migrations/create-quickbooks-oauth-2026-07-20.sql
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_ENVIRONMENT=production
# QUICKBOOKS_REDIRECT_URI=https://resources.sageoutdooradvisory.com/api/admin/quickbooks/oauth/callback
# Optional fallback if not using OAuth connect / DB storage:
# QUICKBOOKS_REALM_ID=
# QUICKBOOKS_REFRESH_TOKEN=
# Intuit webhook verifier (Admin portal → Webhooks). Endpoint:
#   https://resources.sageoutdooradvisory.com/api/webhooks/quickbooks
# Subscribe to Invoice Create + Update. Cron also remaps every 15 minutes.
# QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=

# --- Supabase, maps, and other app secrets (see README / deployment docs) ---
# Google Maps: split browser vs server keys in GCP (see docs/google/GOOGLE_API_KEY_SPLIT_AND_QUOTAS.md)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=   # browser: Maps JS + Autocomplete only
# GOOGLE_PLACES_SERVER_API_KEY=      # server: Places REST + photo proxy only
