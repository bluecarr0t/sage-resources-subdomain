{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/indexnow",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/discover-glamping",
      "schedule": "0 15 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "marketing.sageoutdooradvisory.com"
        }
      ],
      "destination": "https://resources.sageoutdooradvisory.com/$1",
      "permanent": true
    }
  ]
}

