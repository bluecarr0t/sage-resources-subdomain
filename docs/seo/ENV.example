# Copy variables into .env.local (local) or Vercel → Environment Variables (production).
# See docs/seo/PHASE_0_INSTRUMENTATION.md for setup steps.

# GA4 (required)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console HTML-tag verification (content value only)
NEXT_PUBLIC_GOOGLE_VERIFICATION_CODE=

# IndexNow — generate: openssl rand -hex 16
INDEXNOW_KEY=

SITE_URL=https://resources.sageoutdooradvisory.com
CRON_SECRET=
